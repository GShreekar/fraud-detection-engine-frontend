# ─── Fraud Detection API ──────────────────────────────────
# Docker Hub image for the fraud detection engine (standalone mode)
FRAUD_API_IMAGE=yourorg/fraud-detection-engine:latest

# URL the backend uses to proxy requests to the fraud API
# In standalone mode: http://fraud-api:8000  (Docker network)
# In dev mode:        http://host.docker.internal:8000  (host machine)
FRAUD_API_URL=http://fraud-api:8000

# ─── Neo4j ────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Ports ────────────────────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=3001

# ─── Frontend Build ──────────────────────────────────────
VITE_API_URL=/api
VITE_WS_URL=http://localhost:3001
